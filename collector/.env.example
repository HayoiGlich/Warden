# Конфигурация коллектора (один на каждый сервер №1/№2/№3).
# Скопируйте в .env рядом с pars_to_db.py и заполните под конкретный сервер.
# Если python-dotenv не установлен — задайте эти же значения как системные
# переменные окружения (или в задаче планировщика).

# Путь к собранному журналу ForwardedEvents на ЭТОМ сервере (WEF-коллектор)
EVTX_PATH=D:\ForwardedEvents\ForwardedEvents.evtx

# Локальная БД коллектора (импортёр пишет сюда; веб-часть читает её по сети)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=logs
DB_USER=postgres
DB_PASSWORD=unvpa5%w0rd!
