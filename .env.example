# ============================================================
#  Copy this file to .env and fill in real values.
#  NEVER commit the resulting .env (it holds secrets).
# ============================================================

# ---- Collector database (Postgres with Windows event logs, read-only) ----
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=logs
DB_USER=postgres
DB_PASSWORD=change-me

# ---- Active Directory ----
AD_SERVER=10.0.0.10
AD_DOMAIN=EXAMPLE
AD_USERNAME=eventsreader
AD_PASSWORD=change-me
# Encrypted channel is required for creating accounts / changing passwords:
#   LDAPS (port 636):    AD_USE_SSL=1
#   StartTLS over 389:   AD_START_TLS=1
AD_USE_SSL=1
# AD_START_TLS=0
# AD_PORT=636
# AD_AUTH=simple            # simple | ntlm
# AD_TLS_VALIDATE=0         # validate server cert (0 for self-signed internal CA)
# AD_DEFAULT_USER_OU=       # DN of default OU for new accounts (empty = CN=Users)
# AD_UPN_SUFFIX=            # userPrincipalName suffix (empty = AD_DOMAIN)
# AD_LOGIN_GROUP=           # only allow AD users from this group (empty = any)
# DISABLE_AD=0              # 1 to run without AD

# ---- App ----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Auth / sessions ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-to-a-random-string
# App database (auth + app settings) — password of the docker-compose `db` service
APP_DB_PASSWORD=app
# Local admin, seeded on first start if the users table is empty
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=change-me

# ---- OIDC / external 2FA login (optional, e.g. Avanpost) ----
# Discovery: <issuer>/.well-known/openid-configuration
OIDC_ENABLED=0
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_AUTH_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_END_SESSION_URL=
# Must EXACTLY match the redirect URI registered with the IdP
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid profile email
OIDC_USERNAME_CLAIM=preferred_username
OIDC_VERIFY_SSL=0

# ---- Yandex Cloud VM cost report (optional) ----
# Service-account key JSON sits next to the project (see yandex_mig/).
# FAM/Avanpost presence check reuses the OIDC settings above by default.
YC_FOLDER_ID=
YC_KEY_FILE=yandex_mig/authorized_key.json
YC_TEMPLATE_FILE=yandex_mig/Шаблон. Расчет ВМ цена. Общий.xlsx
YC_REPORT_ZONE=
